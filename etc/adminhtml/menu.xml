<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!-- eTechFlow::root is injected at runtime by this module's own
             Plugin/Adminhtml/EnsureEtechflowMenu (idempotent), so the module is
             fully independent and never declares the shared id in XML. A second
             XML declaration of that id would fatal the merged admin menu
             (uniqueAddItemId), so only own-namespace ids are declared here. -->

        <!-- Shipping Table Rates column. -->
        <add id="ETechFlow_ShippingTableRates::root"
             title="Shipping Table Rates"
             module="ETechFlow_ShippingTableRates"
             sortOrder="40"
             parent="eTechFlow::root"
             resource="ETechFlow_ShippingTableRates::manage"/>

        <add id="ETechFlow_ShippingTableRates::manage"
             title="Methods"
             module="ETechFlow_ShippingTableRates"
             sortOrder="10"
             parent="ETechFlow_ShippingTableRates::root"
             action="etechflow_str/method/index"
             resource="ETechFlow_ShippingTableRates::manage"/>

        <!-- Previously the shared id eTechFlow::configuration; moved into this
             module's own namespace so STR declares no shared eTechFlow node. -->
        <add id="ETechFlow_ShippingTableRates::configuration"
             title="Configuration"
             module="ETechFlow_ShippingTableRates"
             sortOrder="20"
             parent="ETechFlow_ShippingTableRates::root"
             action="adminhtml/system_config/edit/section/etechflow_shippingtablerates"
             resource="Magento_Config::config"/>

        <!-- License & Plans gate entry. Reuses the ::config ACL resource. -->
        <add id="ETechFlow_ShippingTableRates::license_gate"
             title="License &amp; Plans"
             module="ETechFlow_ShippingTableRates"
             sortOrder="100"
             parent="ETechFlow_ShippingTableRates::root"
             action="etechflow_str/license/gate"
             resource="ETechFlow_ShippingTableRates::config"/>
    </menu>
</config>
